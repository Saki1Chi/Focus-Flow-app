# Copia este archivo a .env y rellena los valores para desarrollo local.
# En producción (Railway/Render) configura estas variables en el dashboard del hosting.

# Base de datos
# Desarrollo local con SQLite (default si no se define):
# DATABASE_URL=sqlite:///./focusflow.db
# Producción con PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/focusflow
DATABASE_URL=sqlite:///./focusflow.db

# Panel de administración — sin esto /admin devuelve 503
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esto_en_produccion
